# VinR Backend Environment Variables
# Copy to .env and fill in your values

# App
APP_NAME=VinR API
APP_VERSION=0.1.0
DEBUG=true

# Database (Neon PostgreSQL — get your connection string from neon.tech console)
DATABASE_URL=postgresql+asyncpg://user:password@ep-your-endpoint.us-east-2.aws.neon.tech/vinr_db?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379/0

# Clerk Auth (get from clerk.com dashboard)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Firebase Cloud Messaging
FCM_SERVER_KEY=



# CORS
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]
